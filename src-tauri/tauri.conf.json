{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DojoBuro",
  "version": "1.0.0",
  "identifier": "app.dojoburo.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DojoBuro",
        "url": "index.html#app",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      },
      {
        "label": "widget",
        "title": "Dojo Widget",
        "url": "index.html#widget",
        "width": 280,
        "height": 360,
        "minWidth": 200,
        "minHeight": 120,
        "resizable": true,
        "alwaysOnTop": true,
        "decorations": false,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
