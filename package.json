{
  "name": "dojoburo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "DojoBuro — a 2D pixel-art startup office where AI agents work, orchestrated on the XRP Ledger.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc -b --noEmit",
    "typecheck:api": "tsc -p tsconfig.api.json",
    "thumbs": "node scripts/gen-thumbs.mjs",
    "tauri": "tauri",
    "desktop": "tauri dev",
    "desktop:build": "tauri build"
  },
  "dependencies": {
    "@privy-io/react-auth": "^3.33.1",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.160.1",
    "xrpl": "^4.1.0",
    "xumm": "^1.8.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-node-polyfills": "^0.22.0"
  }
}
