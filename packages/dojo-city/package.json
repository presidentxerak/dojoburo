{
  "name": "dojo-city",
  "version": "0.1.0",
  "description": "A self-contained, portable 3D isometric city component for React (Three.js).",
  "type": "module",
  "license": "MIT",
  "keywords": ["react", "three", "3d", "isometric", "city", "r3f", "webgl"],
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node build.mjs && tsc -p tsconfig.json"
  },
  "peerDependencies": {
    "@react-three/drei": ">=9.0.0 <10",
    "@react-three/fiber": ">=8.0.0 <9",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "typescript": "^5.6.3"
  }
}
