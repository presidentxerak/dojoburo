# =============================================================================
# DojoBuro environment variables
# -----------------------------------------------------------------------------
# VITE_* vars are the ONLY ones exposed to the browser. Everything else is
# read only by the server-side support proxy (api/chat.ts) and never shipped
# to the client — keep provider keys OUT of any VITE_ var.
# =============================================================================

# --- Frontend (safe to expose) ----------------------------------------------
# Xaman (XUMM) API KEY for non-custodial Mainnet signing. Only the API KEY,
# never the secret. Get one free: https://apps.xaman.dev
VITE_XUMM_API_KEY=

# Privy app id for account sign-in (email / wallet / social). When set, the
# Dojo Studio "Connect Privy" flow activates; otherwise a local guest account
# is used. Create an app at https://dashboard.privy.io
VITE_PRIVY_APP_ID=

# --- Support chatbot: LLM cascade (server-side only) -------------------------
# Configure any subset. The proxy tries them in order (SUPPORT_CASCADE),
# free tiers first, and only falls back to paid ones under the daily cap.
# With none set, the chatbot still works in free local FAQ mode.

# 1) Groq — free tier, very fast           https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# 2) Google Gemini — free tier             https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# 3) Cerebras — free tier, very fast       https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# 4) OpenRouter — many free models         https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# 5) DeepSeek — paid, ultra-cheap          https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# 6) Anthropic Claude — paid, top quality  https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_SUPPORT_MODEL=claude-haiku-4-5

# --- Support proxy: cascade order + spend limits ----------------------------
# Comma-separated order; only providers with a key set are used.
SUPPORT_CASCADE=groq,gemini,cerebras,openrouter,deepseek,anthropic
# Master kill switch — set to false to force free local FAQ mode only.
SUPPORT_LLM_ENABLED=true
# Hard caps that bound spend deterministically:
SUPPORT_MAX_TOKENS=400            # max output tokens per reply
SUPPORT_MAX_INPUT_CHARS=1500      # max chars per user message
SUPPORT_MAX_MESSAGES=12           # history depth sent upstream
SUPPORT_RATE_MAX=20               # requests per IP per window
SUPPORT_RATE_WINDOW_MS=600000     # rate-limit window (10 min)
SUPPORT_PAID_DAILY_CAP=150        # max PAID upstream calls per day (free tiers unlimited)
SUPPORT_TIMEOUT_MS=12000          # upstream request timeout
# Lock the API to your site origin (recommended in prod), e.g. https://dojoburo.app
SUPPORT_ALLOWED_ORIGIN=

# --- Fiat processor: card top-ups → settle in XRP (server-side only) --------
# When STRIPE_SECRET_KEY is set, the Billing "Add credits" flow creates a
# hosted Stripe Checkout Session (api/checkout.ts) and redirects to it. With
# none set, the endpoint returns not_configured and the UI degrades gracefully
# (fund agents directly in XRP). The charge settles in XRP via x402 in the
# settlement webhook (api/checkout-webhook.ts) — see § Settlement below.
# Stripe secret key (sk_live_… / sk_test_…)  https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhook signing secret for the settlement webhook (whsec_…)
STRIPE_WEBHOOK_SECRET=
# Public site URL for Checkout success/cancel redirects, e.g. https://dojoburo.app
CHECKOUT_SITE_URL=
# Lock checkout to your origin (falls back to SUPPORT_ALLOWED_ORIGIN if unset)
CHECKOUT_ALLOWED_ORIGIN=
# Charge bounds + rate limit (major currency units)
CHECKOUT_MIN_AMOUNT=1
CHECKOUT_MAX_AMOUNT=5000
CHECKOUT_RATE_MAX=12
CHECKOUT_RATE_WINDOW_MS=600000
CHECKOUT_TIMEOUT_MS=12000

# --- § Settlement backend: credit ledger + fiat→XRP payout (server-side) -----
# Powers api/checkout-webhook.ts and api/settle-pending.ts. Apply the schema
# once:  psql "$DATABASE_URL" -f db/schema.sql
# Postgres connection (Supabase / Neon / Vercel Postgres). Use a POOLED URL.
DATABASE_URL=
# Live FX oracle. CoinGecko-style shape { "ripple": { "usd": 2.5, "eur": …, "jpy": … } }
# where the value is the fiat price of 1 XRP. Unset → indicative fallback rates.
# e.g. https://api.coingecko.com/api/v3/simple/price?ids=ripple&vs_currencies=usd,eur,jpy
XRP_PRICE_URL=
# Two settlement models:
#   Mode A (credits)  — leave SETTLEMENT_WALLET_SEED empty. Card top-ups credit
#     an in-app XRP balance (credit_ledger). Simplest, no hot wallet.
#   Mode B (delivery) — set SETTLEMENT_WALLET_SEED. Purchased XRP is delivered
#     on-ledger to the user's own wallet with an x402 memo (self-custody on-ramp).
#     Mainnet recipe: generate a seed PRIVATELY (never in a chat) e.g.
#       node -e "const{Wallet}=require('xrpl');const w=Wallet.generate();console.log(w.classicAddress,w.seed)"
#     fund that address with a SMALL amount, then set SETTLEMENT_NETWORK=mainnet.
# Hot wallet — fund small, rotate.
SETTLEMENT_WALLET_SEED=
SETTLEMENT_NETWORK=testnet          # mainnet | testnet | devnet
# Secret guarding the api/settle-pending cron (Vercel sends it as a Bearer token)
CRON_SECRET=

# =============================================================================
# § Real agent work — Claude deliverables + tool connectors (server-side only)
# -----------------------------------------------------------------------------
# api/agent-run.ts runs a REAL Claude task per agent function and returns an
# actual deliverable (design system, PRD, spec, campaign…). "Claude Design" is
# the design-system engine. Without ANTHROPIC_API_KEY it returns not_configured
# and the app keeps its built-in skill animations — nothing breaks.
# -----------------------------------------------------------------------------
# Billing model — BYOK (recommended): each user brings their OWN Claude key, so
# their runs are billed to THEM and the operator pays ~$0. Text deliverables run
# on the operator's FREE providers (below) up to a per-user daily cap; the design
# system and tool-acting need a Claude key (the user's BYOK key).
#
# Operator Claude key (optional). By default it is NOT spent on user runs.
# ANTHROPIC_API_KEY=            # already defined in the support section
# Set true to offer Claude on the operator's dime (e.g. a hackathon demo):
WORK_OPERATOR_CLAUDE=false
# Free-tier cap: free-cascade runs per account per day on operator keys.
WORK_FREE_DAILY=10
# Models (used with a BYOK key, or operator key when WORK_OPERATOR_CLAUDE=true):
ANTHROPIC_WORK_MODEL=claude-sonnet-5        # default text/tool model (good value)
ANTHROPIC_WORK_MODEL_DESIGN=claude-opus-4-8 # "Claude Design" flagship (best quality)
ANTHROPIC_WORK_MAX_TOKENS=6000
ANTHROPIC_WORK_THINKING=                    # "adaptive" for deeper (slower) reasoning
# Free cascade for text deliverables (reuses the support-provider keys above):
WORK_CASCADE=gemini,groq,cerebras,openrouter
WORK_CASCADE_TIMEOUT_MS=45000
WORK_RATE_MAX=20
WORK_RATE_WINDOW_MS=600000

# --- External-agent proxy (api/agent-proxy.ts) -------------------------------
# Lets a DojoBuro agent link the user's OWN external agents (Notion/Slack/MCP/
# A2A/webhook) and verify + delegate to them server-side (keeps tokens off the
# browser). No new required config: it reuses CHECKOUT_ALLOWED_ORIGIN /
# SUPPORT_ALLOWED_ORIGIN for the same-origin check, and has a built-in SSRF
# guard (blocks localhost / private / cloud-metadata hosts). Optional throttle:
PROXY_RATE_MAX=30
PROXY_RATE_WINDOW_MS=600000

# --- Connect tools per function (OAuth vault) --------------------------------
# Lets a user "branch" real tools onto an agent (Notion, GitHub, Gmail…). Tokens
# are stored ENCRYPTED (AES-256-GCM) and exposed to Claude as remote MCP servers
# at run time. Requires DATABASE_URL (above) + the connectors schema applied:
#   psql "$DATABASE_URL" -f db/connectors.sql
#
# 32-byte key that encrypts vault tokens (base64/hex/passphrase). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CONNECTOR_ENC_KEY=
# Random string signing the OAuth state (falls back to CONNECTOR_ENC_KEY):
CONNECT_STATE_SECRET=
# Public base URL used to build the OAuth redirect_uri = <URL>/api/connect
# (falls back to CHECKOUT_SITE_URL). Register this callback in each provider.
CONNECT_SITE_URL=https://www.dojoburo.com

# Per-tool OAuth client id/secret (enable only the tools you want). Set both to
# turn a connector on; leave blank to show it as "operator setup" in the UI.
# Notion    — https://www.notion.so/my-integrations   (redirect: <URL>/api/connect)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
# GitHub    — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Google (Gmail + Drive) — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_MCP_URL=                 # remote MCP endpoint for Gmail (hub: https://composio.dev)
GDRIVE_MCP_URL=                # remote MCP endpoint for Google Drive
# Slack     — https://api.slack.com/apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_MCP_URL=
# Linear    — https://linear.app/settings/api/applications/new  (MCP default https://mcp.linear.app/mcp)
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
# Stripe (Connect OAuth) — https://dashboard.stripe.com/settings/connect
# client_secret reuses STRIPE_SECRET_KEY above; MCP default https://mcp.stripe.com
STRIPE_CONNECT_CLIENT_ID=
# Figma     — https://www.figma.com/developers/api#oauth2
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
FIGMA_MCP_URL=
# Optional overrides for any connector: <IDP>_AUTH_URL / _TOKEN_URL / _MCP_URL / _SCOPE
# and NOTION_MCP_URL / GITHUB_MCP_URL if you point at a different MCP host.
