# =============================================================================
# DojoBuro environment variables
# -----------------------------------------------------------------------------
# VITE_* vars are the ONLY ones exposed to the browser. Everything else is
# read only by the server-side support proxy (api/chat.ts) and never shipped
# to the client — keep provider keys OUT of any VITE_ var.
# =============================================================================

# --- Frontend (safe to expose) ----------------------------------------------
# Xaman (XUMM) API KEY for non-custodial Mainnet signing. Only the API KEY,
# never the secret. Get one free: https://apps.xaman.dev
VITE_XUMM_API_KEY=

# Privy app id for account sign-in (email / wallet / social). When set, the
# Dojo Studio "Connect Privy" flow activates; otherwise a local guest account
# is used. Create an app at https://dashboard.privy.io
VITE_PRIVY_APP_ID=

# --- Support chatbot: LLM cascade (server-side only) -------------------------
# Configure any subset. The proxy tries them in order (SUPPORT_CASCADE),
# free tiers first, and only falls back to paid ones under the daily cap.
# With none set, the chatbot still works in free local FAQ mode.

# 1) Groq — free tier, very fast           https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# 2) Google Gemini — free tier             https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# 3) Cerebras — free tier, very fast       https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# 4) OpenRouter — many free models         https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# 5) DeepSeek — paid, ultra-cheap          https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# 6) Anthropic Claude — paid, top quality  https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_SUPPORT_MODEL=claude-haiku-4-5

# --- Support proxy: cascade order + spend limits ----------------------------
# Comma-separated order; only providers with a key set are used.
SUPPORT_CASCADE=groq,gemini,cerebras,openrouter,deepseek,anthropic
# Master kill switch — set to false to force free local FAQ mode only.
SUPPORT_LLM_ENABLED=true
# Hard caps that bound spend deterministically:
SUPPORT_MAX_TOKENS=400            # max output tokens per reply
SUPPORT_MAX_INPUT_CHARS=1500      # max chars per user message
SUPPORT_MAX_MESSAGES=12           # history depth sent upstream
SUPPORT_RATE_MAX=20               # requests per IP per window
SUPPORT_RATE_WINDOW_MS=600000     # rate-limit window (10 min)
SUPPORT_PAID_DAILY_CAP=150        # max PAID upstream calls per day (free tiers unlimited)
SUPPORT_TIMEOUT_MS=12000          # upstream request timeout
# Lock the API to your site origin (recommended in prod), e.g. https://dojoburo.app
SUPPORT_ALLOWED_ORIGIN=
