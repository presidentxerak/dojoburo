# =============================================================================
# DojoBuro · .env de démarrage (tout gratuit)
# -----------------------------------------------------------------------------
# Copie ces variables dans Vercel (Project → Settings → Environment Variables),
# ou en local : `cp .env.starter .env`. Remplace les valeurs <A_COLLER>.
# Référence exhaustive de TOUTES les variables : voir .env.example
# =============================================================================

# --- 1) UN modèle IA (gratuit) — le CEO produit du VRAI contenu -------------
# Clé Groq gratuite : https://console.groq.com/keys  (aucune carte requise)
GROQ_API_KEY=<A_COLLER>
# Ordre d'essai des fournisseurs gratuits (tu peux en ajouter d'autres) :
WORK_CASCADE=groq,gemini,cerebras,openrouter
# (facultatif) Gemini gratuit en secours : https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- 2) Base de données (gratuit) — crédits, coffres, secrets ---------------
# Neon (https://neon.tech) ou Supabase — prends l'URL "pooled".
# Puis applique les 3 schémas UNE fois :
#   psql "$DATABASE_URL" -f db/schema.sql
#   psql "$DATABASE_URL" -f db/connectors.sql
#   psql "$DATABASE_URL" -f db/secrets.sql
DATABASE_URL=<A_COLLER>

# --- 3) Clé de chiffrement du coffre (32 octets) ----------------------------
# Génère-la : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CONNECTOR_ENC_KEY=<A_COLLER>

# --- 4) Compte admin (tests illimités gratuits) -----------------------------
# Ces emails testent TOUS les outils sans plafond quotidien. Connecte-toi avec
# Privy avec cet email pour activer le mode ADMIN.
ADMIN_EMAILS=presidentxerak@gmail.com
# Autorise l'admin à utiliser une clé Claude opérateur si tu en mets une :
WORK_OPERATOR_CLAUDE=false
# (facultatif) Clé Claude opérateur pour la meilleure qualité + Claude Design.
# Si tu la mets ET que tu es admin, tes runs Claude sont illimités pour toi.
# ANTHROPIC_API_KEY=

# --- 5) Login (recommandé) ---------------------------------------------------
# App Privy : https://dashboard.privy.io  (sans, un compte invité local est créé
# mais le mode admin exige un vrai login avec l'email ci-dessus).
VITE_PRIVY_APP_ID=<A_COLLER>

# --- 6) URL publique (pour les redirections OAuth / Checkout) ---------------
CONNECT_SITE_URL=https://www.dojoburo.com
CHECKOUT_SITE_URL=https://www.dojoburo.com

# =============================================================================
# OPTIONNEL — active seulement ce que tu veux tester
# =============================================================================
# Paiements par carte (agent Crédit) — https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# Connecteurs par agent — <IDP>_CLIENT_ID + <IDP>_CLIENT_SECRET :
#   Acquisition : META_CLIENT_ID / META_CLIENT_SECRET   (Meta Ads)
#   Outbound    : GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET (Gmail)
#   Revenu      : STRIPE_CONNECT_CLIENT_ID   (secret = STRIPE_SECRET_KEY)
#   Web         : FIGMA_CLIENT_ID / FIGMA_CLIENT_SECRET
# Redirect OAuth à enregistrer chez chaque provider : <CONNECT_SITE_URL>/api/connect
